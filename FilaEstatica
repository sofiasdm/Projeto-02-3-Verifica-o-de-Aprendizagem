class FilaEstatica {
    private Minerador[] elementos;
    private int inicio;
    private int fim;
    private int tamanho;
    private int capacidade;

    public FilaEstatica(int capacidade) {
        this.capacidade = capacidade;
        this.elementos = new Minerador[capacidade];
        this.inicio = 0;
        this.fim = 0;
        this.tamanho = 0;
    }

    public boolean enfileirar(Minerador m) {
        if (tamanho == capacidade) return false; // Fila cheia
        elementos[fim] = m;
        fim = (fim + 1) % capacidade;
        tamanho++;
        return true;
    }

    public Minerador desenfileirar() {
        if (tamanho == 0) return null; // Fila vazia
        Minerador m = elementos[inicio];
        elementos[inicio] = null;
        inicio = (inicio + 1) % capacidade;
        tamanho--;
        return m;
    }

    public boolean estaVazia() {
        return tamanho == 0;
    }
}
